<!--
    This is the configuration file for XPDBench parameters.
-->

<xpdbenchConfig xmlns="http://www.ist.utl.pt">

    <!--Number of array elements. The benchmark contains a List
    of double arrays. Here you are giving the number of elements.
    For example, 1020 will initialize
        bigArray = new double[1020][1020]
    where the List contains 1020 such double array objects, as below.
        for (int i = 0; i < 1020; i++) {
            bigList.add(bigArray); Default = 1000
    So the effect of increasing the size (n) here in the size of the
    object is n^3.-->
    <objectSize>1000</objectSize>

    <!--Is Garbage Collection induced by the benchmark? 
    Default is true. If set to false, the GC algorithm will take 
    complete control on when to schedule collection.-->
    <isGCInduced>true</isGCInduced>

    <!--How many iteration the memory consuming method to be run.
    Default is 10.-->
    <iteration>15</iteration>

    <!--How many threads should be used in the benchmarking program.
    Default is 10.-->
    <threadCount>10</threadCount>

    <!--How long should each thread sleep after the memory consuming
    method being invoked. Given in milliseconds. Default is 10-->
    <sleepTime>10</sleepTime>

</xpdbenchConfig>
